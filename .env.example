# =============================================================================
# SISPAD-PEI-POA — Variables de Entorno
# =============================================================================
# Copiar a .env y ajustar valores:
#   cp .env.example .env
#
# Por seguridad, NUNCA committear .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=changeme-generar-clave-segura
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Base de Datos PostgreSQL / PostGIS
# -----------------------------------------------------------------------------
DB_ENGINE=django.contrib.gis.db.backends.postgis
DB_NAME=gams_sis_poa
DB_USER=sispoa_user
DB_PASSWORD=changeme-segura
DB_HOST=sispoa-postgres
DB_PORT=5432

# Variables usadas directamente por el contenedor postgres
POSTGRES_DB=gams_sis_poa
POSTGRES_USER=sispoa_user
POSTGRES_PASSWORD=changeme-segura

# -----------------------------------------------------------------------------
# Redis (caché + celery)
# -----------------------------------------------------------------------------
REDIS_HOST=sispoa-redis
REDIS_PORT=6379
REDIS_URL=redis://sispoa-redis:6379/1

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# -----------------------------------------------------------------------------
# Celery — tareas asíncronas (Fase 3)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://sispoa-redis:6379/0
CELERY_RESULT_BACKEND=redis://sispoa-redis:6379/0

# -----------------------------------------------------------------------------
# MinIO S3 — almacenamiento de objetos (Fase 4)
# Activar con USE_S3=True
# -----------------------------------------------------------------------------
USE_S3=False
MINIO_ENDPOINT=http://sispoa-minio:9000
MINIO_ROOT_USER=sispoa_admin
MINIO_ROOT_PASSWORD=changeme-minio-segura
MINIO_BUCKET_NAME=sispoa-docs
AWS_ACCESS_KEY_ID=sispoa_admin
AWS_SECRET_ACCESS_KEY=changeme-minio-segura
AWS_STORAGE_BUCKET_NAME=sispoa-docs
AWS_S3_REGION_NAME=us-east-1

# -----------------------------------------------------------------------------
# GeoServer — servicios de mapas (Fase 4)
# -----------------------------------------------------------------------------
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=changeme-geoserver
GEOSERVER_URL=http://sispoa-geoserver:8080/geoserver

# -----------------------------------------------------------------------------
# Keycloak / OIDC — autenticación externa (Fase 5)
# Activar cuando OIDC_RP_CLIENT_ID esté presente
# -----------------------------------------------------------------------------
OIDC_RP_CLIENT_ID=sispoa-frontend
OIDC_RP_CLIENT_SECRET=changeme-oidc-secret
OIDC_OP_AUTHORITY=http://sispoa-keycloak:8080/realms/sispoa
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme-keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=changeme-keycloak
